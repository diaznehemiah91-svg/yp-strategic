# ─────────────────────────────────────────────────────────
# Y.P Strategic Research — Environment Variables
# Copy this to .env.local and fill in your API keys
# ─────────────────────────────────────────────────────────

# ── STOCK DATA (Alpha Vantage) ──
ALPHA_VANTAGE_API_KEY=your_key_here
# Free: 5 calls/min, 500/day | Premium: $49.99/mo unlimited
# Sign up: https://www.alphavantage.co/support/#api-key

# ── STOCK DATA (Finnhub — PRIMARY) ──
FINNHUB_KEY=your_key_here
# Free: 60 calls/min | Sign up: https://finnhub.io/register

# ── NEWS ──
NEWSAPI_KEY=your_key_here
# Free: 100 req/day (dev only) | Business: $449/mo

# ── CRYPTO ──
COINMARKETCAP_API_KEY=your_key_here
# Basic: Free (333 calls/day) | Startup: $79/mo

# ── FUTURES / MACRO ──
FRED_API_KEY=your_key_here
# Free unlimited (Federal Reserve data)

# ── GEOPOLITICAL RISK ──
GDELT_ENABLED=true

# ── AUTH (Clerk) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_key_here
CLERK_SECRET_KEY=your_key_here

# ── PAYMENTS (Stripe) ──
STRIPE_SECRET_KEY=your_key_here
STRIPE_WEBHOOK_SECRET=your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_key_here

# ── DATABASE ──
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── GOOGLE ADSENSE ──
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ── APP CONFIG ──
NEXT_PUBLIC_APP_URL=https://ypstrategicresearch.com
NEXT_PUBLIC_APP_NAME="Y.P Strategic Research"
NODE_ENV=production
# ═══════════════════════════════════════════════════════════
# ypstrategicresearch.com — Environment Variables
# Copy this to .env.local and fill in your API keys
# ═══════════════════════════════════════════════════════════

# ── STOCK DATA (Finnhub — PRIMARY) ──
# REQUIRED: Used by /api/stock-price and /api/company-news routes
# Without this key, all stock prices and company news fall back to mock data
FINNHUB_KEY=your_key_here
# Free: 60 calls/min | Premium: $0/mo (free tier is sufficient)
# Sign up: https://finnhub.io/register

# ── STOCK DATA (Alpha Vantage — LEGACY, not currently used in routes) ──
ALPHA_VANTAGE_API_KEY=your_key_here
# Free: 5 calls/min, 500/day | Premium: $49.99/mo unlimited
# Sign up: https://www.alphavantage.co/support/#api-key

# ── NEWS ──
# NOTE: Company news is fetched via Finnhub (FINNHUB_KEY above).
# NEWSAPI_KEY is checked in fetchers.ts before enabling live news —
# set it to a real key (or any non-placeholder value) to enable the Finnhub news feed.
NEWSAPI_KEY=your_key_here
# Free: 100 req/day (dev only) | Business: $449/mo
# Sign up: https://newsapi.org/register

# ── CRYPTO ──
COINMARKETCAP_API_KEY=your_key_here
# Basic: Free (333 calls/day) | Startup: $79/mo
# Sign up: https://pro.coinmarketcap.com/signup

# ── FUTURES / MACRO ──
FRED_API_KEY=your_key_here
# Free unlimited (Federal Reserve data)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html

# ── GEOPOLITICAL RISK ──
GDELT_ENABLED=true
# Free — no key needed, uses GDELT 2.0 API

# ── AUTH (Clerk) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_key_here
CLERK_SECRET_KEY=your_key_here
# Sign up: https://clerk.com

# ── PAYMENTS (Stripe) ──
STRIPE_SECRET_KEY=your_key_here
STRIPE_WEBHOOK_SECRET=your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_key_here
# Sign up: https://dashboard.stripe.com/register

# ── DATABASE (PostgreSQL on Railway) ──
DATABASE_URL=postgresql://user:password@host:port/dbname
# Railway auto-provisions this when you add PostgreSQL

# ── GOOGLE ADSENSE ──
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Sign up: https://adsense.google.com

# ── APP CONFIG ──
NEXT_PUBLIC_APP_URL=https://ypstrategicresearch.com
NEXT_PUBLIC_APP_NAME="ypstrategicresearch.com"
NODE_ENV=production
